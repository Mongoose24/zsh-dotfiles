add_newline = false
palette = "catppuccin_frappe"
command_timeout = 1000

format = """
$directory$git_branch$git_status
${custom.venv}$character"""

right_format = """$cmd_duration$time"""

[character]
success_symbol = '[❯](mauve)'
error_symbol = '[❮](red)'
vicmd_symbol = '[❮](green)'

[directory]
style = "blue bold"
truncation_length = 8
truncate_to_repo = false

[directory.substitutions]
# '~/zsh-dotfiles' = 'zdot'
'~/ELYSIUM/PERSONAL VAULT' = '(PERSONAL)/'
'~/ELYSIUM/LP VAULT' = '(LINT)/'
'~/ELYSIUM/MESKO VAULT' = '(MESKO)/'
'~/ELYSIUM/AGENT VAULT' = '(AGENT)/'

[git_branch]
format = ' [$symbol$branch]($style)'
style = "overlay2"

[git_status]
format = '([$all_status$ahead_behind]($style))'
style = "overlay1"
ahead = "⇡"
behind = "⇣"
diverged = "⇕"
modified = "*"
staged = "+"
untracked = "?"
deleted = "✘"

[cmd_duration]
min_time = 2000
format = '[$duration](yellow) '

[time]
disabled = false
format = '[$time](overlay2)'
time_format = '%I:%M %p'

[aws]
disabled = true

[gcloud]
disabled = true

[nodejs]
disabled = true

[golang]
disabled = true

[custom.venv]
command = "basename $(dirname $VIRTUAL_ENV)"
when = '[ -n "$VIRTUAL_ENV" ]'
format = '[$output❯](surface2)'

[rust]
disabled = true

[docker_context]
disabled = true

[kubernetes]
disabled = true

[package]
disabled = true

[palettes.catppuccin_frappe]
rosewater = "#f2d5cf"
flamingo = "#eebebe"
pink = "#f4b8e4"
mauve = "#ca9ee6"
red = "#e78284"
maroon = "#ea999c"
peach = "#ef9f76"
yellow = "#e5c890"
green = "#a6d189"
teal = "#81c8be"
sky = "#99d1db"
sapphire = "#85c1dc"
blue = "#8caaee"
lavender = "#babbf1"
text = "#c6d0f5"
subtext1 = "#b5bfe2"
subtext0 = "#a5adce"
overlay2 = "#949cbb"
overlay1 = "#838ba7"
overlay0 = "#737994"
surface2 = "#626880"
surface1 = "#51576d"
surface0 = "#414559"
base = "#303446"
mantle = "#292c3c"
crust = "#232634"



