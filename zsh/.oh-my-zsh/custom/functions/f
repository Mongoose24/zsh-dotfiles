file=$(fzf \
  --bind 'alt-n:execute(nano {})' \
  --preview '
    case "$1" in
      *.svg) resvg {} /tmp/fzf-preview.png 2>/dev/null && chafa /tmp/fzf-preview.png ;;
      *.png|*.jpg|*.jpeg|*.gif|*.webp) chafa {} ;;
      *) bat --color=always {} 2>/dev/null || cat {} ;;
    esac
  ' \
  --preview-window right:50%:wrap)
